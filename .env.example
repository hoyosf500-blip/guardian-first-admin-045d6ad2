; Plantilla para .env. Copiar a .env y completar con valores reales.
; El .env real está en .gitignore (no se commitea).

; --- Conexión a Supabase (ambos requeridos) ---
; Se obtienen de tu proyecto Supabase → Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

; --- Módulos opcionales ---
; CFO: vista financiera personal del dueño original (deuda TC, tarjetas
; personales, bitácora). Build-time, NO configurable desde la UI. Para
; clientes externos dejar comentado: la ruta /cfo no se registra y
; devuelve 404.
; VITE_ENABLE_CFO=true
